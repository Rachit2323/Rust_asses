# SQLite database file (created automatically on first run)
DATABASE_URL=sqlite://data.db

# Secret used to sign JWT access tokens - change in production
JWT_SECRET=sjdijhifdhidfnk3444334jiefj

# JWT access token lifetime, in seconds (default: 1 hour)
JWT_EXPIRY_SECONDS=3600

# 2FA verification code lifetime, in seconds (default: 5 minutes)
TWO_FACTOR_CODE_TTL_SECONDS=300

# Per-user "view-my-tasks" cache TTL, in seconds
TASKS_CACHE_TTL_SECONDS=60

# HTTP server port
PORT=8080
